{
  "name": "@tomfrenzel/hortusfox-mcp",
  "version": "v1.0.1-beta.1",
  "description": "Model Context Protocol (stdio) server for HortusFox-web, wrapping its REST API.",
  "type": "module",
  "bin": {
    "hortusfox-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "hortusfox",
    "plants",
    "gardening"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3"
  }
}
